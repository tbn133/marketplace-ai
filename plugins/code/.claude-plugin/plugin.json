{
  "name": "code",
  "version": "0.2.0",
  "description": "AST-based code indexing, call graph analysis, semantic search, and persistent business memory. Supports multi-repo sharing via central HTTP MCP server.",
  "author": {
    "name": "tbnvn"
  },
  "license": "MIT",
  "keywords": ["code-intelligence", "ast", "call-graph", "semantic-search", "memory"],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "diff -q \"${CLAUDE_PLUGIN_ROOT}/requirements.txt\" \"${CLAUDE_PLUGIN_DATA}/requirements.txt\" >/dev/null 2>&1 || (python3 -m venv \"${CLAUDE_PLUGIN_DATA}/venv\" && \"${CLAUDE_PLUGIN_DATA}/venv/bin/pip\" install --quiet --disable-pip-version-check -r \"${CLAUDE_PLUGIN_ROOT}/requirements.txt\" && cp \"${CLAUDE_PLUGIN_ROOT}/requirements.txt\" \"${CLAUDE_PLUGIN_DATA}/\") || rm -f \"${CLAUDE_PLUGIN_DATA}/requirements.txt\""
          }
        ]
      }
    ]
  }
}
